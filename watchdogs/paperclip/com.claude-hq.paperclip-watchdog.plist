<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Paperclip Watchdog (Tier 1)

  NOT auto-loaded. To install:
    cp ~/claude-hq/watchdogs/paperclip/com.claude-hq.paperclip-watchdog.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.claude-hq.paperclip-watchdog.plist
    launchctl kickstart -k gui/$(id -u)/com.claude-hq.paperclip-watchdog

  To uninstall:
    launchctl bootout gui/$(id -u)/com.claude-hq.paperclip-watchdog
    rm ~/Library/LaunchAgents/com.claude-hq.paperclip-watchdog.plist

  First 14 days: observe-only soak (--soak flag). After soak, change --soak to --active.

  Cycle: 5 minutes (faster than PATS's 30-min static scan because Paperclip
  rules are runtime probes — burn rate spikes evolve in minutes).
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-hq.paperclip-watchdog</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>PAPERCLIP_URL</key>
    <string>http://localhost:3100</string>
  </dict>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>/Users/sunil_rajput/claude-hq/watchdogs/paperclip/orchestrator.py</string>
    <string>--soak</string>
  </array>

  <key>StandardOutPath</key>
  <string>/Users/sunil_rajput/claude-hq/watchdogs/paperclip/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/sunil_rajput/claude-hq/watchdogs/paperclip/launchd.err.log</string>

  <key>WorkingDirectory</key>
  <string>/Users/sunil_rajput/claude-hq/watchdogs/paperclip</string>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>LowPriorityIO</key>
  <true/>

  <key>ProcessType</key>
  <string>Background</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
