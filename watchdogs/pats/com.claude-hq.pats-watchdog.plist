<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  PATS-Copy Architectural Watchdog (Tier 1)

  NOT auto-loaded. To install:
    cp ~/claude-hq/watchdogs/pats/com.claude-hq.pats-watchdog.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.claude-hq.pats-watchdog.plist
    launchctl kickstart -k gui/$(id -u)/com.claude-hq.pats-watchdog

  To uninstall:
    launchctl bootout gui/$(id -u)/com.claude-hq.pats-watchdog
    rm ~/Library/LaunchAgents/com.claude-hq.pats-watchdog.plist

  Activated 2026-05-11: flipped from --soak to --active.
  - Branch 2 shadow window proved the divergence-recall-low metric was invalid
    (data-api not ground truth); that sub-check was disabled in
    branch2_shadow_health.py before flip to avoid alert spam on a broken premise.
  - Other rules (ws-disconnected, no-blocks, divergence-latency-slow,
    supabase-consistency, low-priced-SELL, pnl-write-reliability) remain active.
  - Telegram routes warn alerts at 1-hour cooldown, critical alerts immediately.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-hq.pats-watchdog</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>/Users/sunil_rajput/claude-hq/watchdogs/pats/orchestrator.py</string>
    <string>--active</string>
  </array>

  <key>StandardOutPath</key>
  <string>/Users/sunil_rajput/claude-hq/watchdogs/pats/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/sunil_rajput/claude-hq/watchdogs/pats/launchd.err.log</string>

  <key>WorkingDirectory</key>
  <string>/Users/sunil_rajput/claude-hq/watchdogs/pats</string>

  <key>StartInterval</key>
  <integer>1800</integer>

  <key>LowPriorityIO</key>
  <true/>

  <key>ProcessType</key>
  <string>Background</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
