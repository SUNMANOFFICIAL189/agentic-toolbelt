# HQ Watchdog — configuration template
# Copy this file to .env. The .env file is gitignored.
#
# Credentials are NOT read from this file at runtime. They are read from
# macOS Keychain (following claude-hq Rule 15 — Keychain + launchers for
# MCP-style secrets). This file only lets you override non-secret settings.

# --- Secret references (stored in macOS Keychain, not here) ---
# The watchdog looks up these keychain entries by name:
TELEGRAM_TOKEN_KEYCHAIN=claude-hq-watchdog-token
TELEGRAM_CHAT_ID_KEYCHAIN=claude-hq-watchdog-chat-id

# --- Optional overrides ---

# Disable the watchdog entirely without uninstalling (useful during
# long refactors where you don't want noise).
# WATCHDOG_ENABLED=false

# Change the daily digest time (24h, local time). Default 08:00.
# DAILY_DIGEST_TIME=08:00

# Change the weekly evolution digest day/time. Default Sunday 08:00.
# WEEKLY_DIGEST_DAY=Sunday
# WEEKLY_DIGEST_TIME=08:00

# Minimum sessions before the watchdog starts sending non-critical alerts.
# Default 7 — roughly a week of normal HQ use.
# BASELINE_WARMUP_SESSIONS=7
