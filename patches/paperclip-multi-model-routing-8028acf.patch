+/**
+ * Model routing doctrine — typed translation of HQ Commander's
+ * `~/claude-hq/commander/MODEL_ROUTING.md` for use inside Paperclip.
+ *
+ * This file is data + types only. Decision logic lives in `router.ts`.
+ *
+ * Design notes:
+ * - V1 routes by *agent kind* (not free-text task description). Paperclip
+ *   agents have stable roles; per-issue keyword routing is deferred until
+ *   we have soak data showing agent-kind routing is insufficient.
+ * - Hard floor list refuses downgrade for adversarial / high-stakes work.
+ * - Tiers are abstract (haiku / sonnet / opus); concrete model strings are
+ *   resolved via {@link TIER_TO_MODEL}. Update one place when Anthropic ships
+ *   a new generation.
+ * - The doctrine *never* changes which provider is called by adapter
+ *   internals — it only proposes a `model:` field on the resolved config.
+ *   Adapters that ignore `config.model` (e.g. plain webhook adapters) are
+ *   unaffected.
+ */
+
+export type Tier = "haiku" | "sonnet" | "opus";
+
+/**
+ * Concrete Anthropic model identifiers per tier.
+ * Synchronised with HQ Commander's MODEL_ROUTING.md §11 context-window table.
+ *
+ * Update points when models roll forward:
+ * - Bump these strings.
+ * - Cross-check with HQ Commander/MODEL_ROUTING.md §11 stays the source of truth.
+ */
+export const TIER_TO_MODEL: Record<Tier, string> = {
+  haiku: "claude-haiku-4-5-20251001",
+  sonnet: "claude-sonnet-4-6",
+  opus: "claude-opus-4-7",
+};
+
+export const DEFAULT_TIER: Tier = "sonnet";
+
+/**
+ * Numeric ordering: higher tier = higher number. Used for floor + ranking.
+ */
+export const TIER_RANK: Record<Tier, number> = {
+  haiku: 0,
+  sonnet: 1,
+  opus: 2,
+};
+
+/**
+ * Hard floor — agent kinds that refuse all downgrades. Even quota-aware
+ * degradation skips them. Match is case-insensitive substring against
+ * agent.name / agent.role / agent.kind.
+ *
+ * Source: MODEL_ROUTING.md §4.
+ */
+export const HARD_FLOOR_PATTERNS: readonly string[] = [
+  "red-team",
+  "redteam",
+  "adversarial",
+  "reviewer",
+  "review-",
+  "security-review",
+  "code-review",
+  "legal-review",
+  "legal",
+  "compliance",
+  "investor-comms",
+  "investor-materials",
+  "investor-outreach",
+  "investor",
+  "architect",
+  "code-architect",
+];
+
+/**
+ * One row of the doctrine table — match by keyword in agent kind/role,
+ * pick the tier. Higher priority wins ties.
+ *
+ * Source: MODEL_ROUTING.md §5 — adapted from "task shape" to "agent kind"
+ * because Paperclip agents are stable role-bearing personas.
+ */
+export interface DoctrineRow {
+  keywords: readonly string[];
+  tier: Tier;
+  priority: number;
+  description: string;
+}
+
+export const KEYWORD_TIER_TABLE: readonly DoctrineRow[] = [
+  // Opus tier — high-stakes / architectural / synthesis. Most also catch via hard floor.
+  {
+    keywords: ["architect", "design-system", "blueprint", "planner", "ceo", "strategy"],
+    tier: "opus",
+    priority: 30,
+    description: "architecture / strategic planning / CEO-level synthesis",
+  },
+  {
+    keywords: ["red-team", "adversarial", "threat-model", "contradict", "challenge"],
+    tier: "opus",
+    priority: 30,
+    description: "adversarial reasoning",
+  },
+  {
+    keywords: ["investor", "pitch", "deck", "memo", "fundraise"],
+    tier: "opus",
+    priority: 30,
+    description: "investor-facing communication",
+  },
+  {
+    keywords: ["legal", "compliance", "regulatory", "license"],
+    tier: "opus",
+    priority: 30,
+    description: "legal / compliance work",
+  },
+  {
+    keywords: ["researcher", "analyst", "synthesis"],
+    tier: "opus",
+    priority: 25,
+    description: "deep research / multi-source synthesis (event-driven Opus per quota incident lesson)",
+  },
+
+  // Sonnet tier — default for most coding/builder/standard work.
+  {
+    keywords: ["builder", "engineer", "developer", "implement", "tdd", "test"],
+    tier: "sonnet",
+    priority: 20,
+    description: "standard implementation work",
+  },
+  {
+    keywords: ["refactor", "restructure", "decompose"],
+    tier: "sonnet",
+    priority: 20,
+    description: "refactoring proposals",
+  },
+  {
+    keywords: ["pm", "product-manager", "coordinator"],
+    tier: "sonnet",
+    priority: 18,
+    description: "product / coordination",
+  },
+
+  // Haiku tier — bounded mechanical work.
+  {
+    keywords: ["validator", "linter", "formatter", "checker"],
+    tier: "haiku",
+    priority: 10,
+    description: "mechanical validation / format / lint",
+  },
+  {
+    keywords: ["classifier", "tagger", "labeler", "summariser", "summarizer"],
+    tier: "haiku",
+    priority: 10,
+    description: "classification / summarisation",
+  },
+  {
+    keywords: ["watcher", "monitor", "ping"],
+    tier: "haiku",
+    priority: 10,
+    description: "lightweight monitoring",
+  },
+];
