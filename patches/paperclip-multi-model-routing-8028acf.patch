+import { describe, expect, it } from "vitest";
+import { routeModel } from "./router.js";
+import { TIER_TO_MODEL } from "./doctrine.js";
+
+const noEnv = {} as NodeJS.ProcessEnv;
+
+describe("routeModel — defaults and doctrine match", () => {
+  it("returns sonnet when no agent kind matches and no current model", () => {
+    const d = routeModel({
+      agentKind: "totally-unknown-kind",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+    expect(d.model).toBe(TIER_TO_MODEL.sonnet);
+    expect(d.overrideReason).toBe("default");
+    expect(d.matchedKeyword).toBeNull();
+    expect(d.passthrough).toBe(false);
+  });
+
+  it("routes builder agents to sonnet via doctrine", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+    expect(d.overrideReason).toBe("doctrine_match");
+    expect(d.matchedKeyword).toBe("builder");
+  });
+
+  it("routes validator agents to haiku via doctrine when no current tier set", () => {
+    const d = routeModel({
+      agentKind: "validator",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("haiku");
+    expect(d.overrideReason).toBe("doctrine_match");
+    expect(d.matchedKeyword).toBe("validator");
+  });
+
+  it("routes researcher agents to opus", () => {
+    const d = routeModel({
+      agentKind: "Researcher",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+  });
+});
+
+describe("routeModel — hard floor", () => {
+  it("forces opus for any agent kind matching the hard floor", () => {
+    const d = routeModel({
+      agentKind: "code-reviewer",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("hard_floor");
+  });
+
+  it("hard floor beats HQ_MODEL_OVERRIDE=haiku", () => {
+    const d = routeModel({
+      agentKind: "security-reviewer",
+      currentModel: null,
+      env: { HQ_MODEL_OVERRIDE: "haiku" } as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("hard_floor");
+  });
+
+  it("hard floor catches investor-facing kinds", () => {
+    const d = routeModel({
+      agentKind: "investor-outreach-agent",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("hard_floor");
+  });
+
+  it("hard floor catches legal", () => {
+    const d = routeModel({
+      agentKind: "legal-counsel-bot",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("hard_floor");
+  });
+
+  it("hard floor escalates even when current model is already Haiku", () => {
+    const d = routeModel({
+      agentKind: "code-reviewer",
+      currentModel: "claude-haiku-4-5-20251001",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("hard_floor");
+  });
+});
+
+describe("routeModel — env overrides", () => {
+  it("HQ_ROUTER_OFF=1 returns currentModel verbatim and marks passthrough", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "claude-foo-99",
+      env: { HQ_ROUTER_OFF: "1" } as NodeJS.ProcessEnv,
+    });
+    expect(d.passthrough).toBe(true);
+    expect(d.model).toBe("claude-foo-99");
+    expect(d.overrideReason).toBe("router_off");
+  });
+
+  it("HQ_MODEL_OVERRIDE=opus forces opus on a builder agent", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: null,
+      env: { HQ_MODEL_OVERRIDE: "opus" } as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("env_override");
+  });
+
+  it("HQ_MODEL_OVERRIDE=haiku is honoured even if current model is Sonnet (explicit user intent)", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "claude-sonnet-4-5-20250929",
+      env: { HQ_MODEL_OVERRIDE: "haiku" } as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("haiku");
+    expect(d.overrideReason).toBe("env_override");
+  });
+
+  it("invalid HQ_MODEL_OVERRIDE value is ignored — doctrine wins", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: null,
+      env: { HQ_MODEL_OVERRIDE: "garbage" } as NodeJS.ProcessEnv,
+    });
+    expect(d.overrideReason).toBe("doctrine_match");
+  });
+
+  it("HQ_MODEL_FLOOR=sonnet raises a haiku validator to sonnet", () => {
+    const d = routeModel({
+      agentKind: "validator",
+      currentModel: null,
+      env: { HQ_MODEL_FLOOR: "sonnet" } as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+    expect(d.overrideReason).toBe("floor_raised");
+  });
+
+  it("HQ_MODEL_FLOOR=haiku does NOT lower an opus researcher", () => {
+    const d = routeModel({
+      agentKind: "researcher",
+      currentModel: null,
+      env: { HQ_MODEL_FLOOR: "haiku" } as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("opus");
+  });
+
+  it("router_off short-circuits even when other env vars are set", () => {
+    const d = routeModel({
+      agentKind: "code-reviewer",
+      currentModel: "claude-some-x",
+      env: { HQ_ROUTER_OFF: "1", HQ_MODEL_OVERRIDE: "haiku" } as NodeJS.ProcessEnv,
+    });
+    expect(d.passthrough).toBe(true);
+    expect(d.model).toBe("claude-some-x");
+  });
+});
+
+describe("routeModel — non-Anthropic passthrough (safety rule, 2026-05-08)", () => {
+  it("gemini model on Planner stays on Gemini — recreates the 2026-04-28 safety guarantee", () => {
+    const d = routeModel({
+      agentKind: "Planner",
+      currentModel: "gemini-2.5-flash",
+      env: noEnv,
+    });
+    expect(d.passthrough).toBe(true);
+    expect(d.model).toBe("gemini-2.5-flash");
+    expect(d.overrideReason).toBe("non_anthropic_passthrough");
+  });
+
+  it("gpt model is left alone", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "gpt-4-turbo",
+      env: noEnv,
+    });
+    expect(d.passthrough).toBe(true);
+    expect(d.model).toBe("gpt-4-turbo");
+    expect(d.overrideReason).toBe("non_anthropic_passthrough");
+  });
+
+  it("kimi-k2 is left alone (not Claude-shaped, not Anthropic)", () => {
+    const d = routeModel({
+      agentKind: "researcher",
+      currentModel: "kimi-k2-instruct",
+      env: noEnv,
+    });
+    expect(d.passthrough).toBe(true);
+    expect(d.overrideReason).toBe("non_anthropic_passthrough");
+  });
+
+  it("Claude-shaped current model still goes through doctrine", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "claude-sonnet-4-5-20250929",
+      env: noEnv,
+    });
+    expect(d.passthrough).toBe(false);
+    expect(d.tier).toBe("sonnet");
+  });
+
+  it("non-Anthropic passthrough still honoured even if hard-floor agent kind", () => {
+    // Operator deliberately put a security reviewer on Gemini — that's their call.
+    // Cross-provider trumps doctrine, even hard floor.
+    const d = routeModel({
+      agentKind: "security-reviewer",
+      currentModel: "gemini-2.5-pro",
+      env: noEnv,
+    });
+    expect(d.passthrough).toBe(true);
+    expect(d.model).toBe("gemini-2.5-pro");
+    expect(d.overrideReason).toBe("non_anthropic_passthrough");
+  });
+
+  it("HQ_ROUTER_OFF wins over non-Anthropic passthrough (router_off is explicit)", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "gemini-2.5-flash",
+      env: { HQ_ROUTER_OFF: "1" } as NodeJS.ProcessEnv,
+    });
+    expect(d.overrideReason).toBe("router_off");
+  });
+});
+
+describe("routeModel — current tier as floor (safety rule, 2026-05-08)", () => {
+  it("Validator on Sonnet stays on Sonnet — doctrine's Haiku is not an allowed downgrade", () => {
+    const d = routeModel({
+      agentKind: "validator",
+      currentModel: "claude-sonnet-4-5-20250929",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+    expect(d.overrideReason).toBe("current_tier_floor");
+  });
+
+  it("Validator on Opus stays on Opus", () => {
+    const d = routeModel({
+      agentKind: "validator",
+      currentModel: "claude-opus-4-7",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("current_tier_floor");
+  });
+
+  it("Validator on Haiku stays on Haiku — doctrine matches, no upgrade needed", () => {
+    const d = routeModel({
+      agentKind: "validator",
+      currentModel: "claude-haiku-4-5-20251001",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("haiku");
+    expect(d.overrideReason).toBe("doctrine_match");
+  });
+
+  it("Builder on Haiku is upgraded to Sonnet — doctrine escalates as expected", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "claude-haiku-4-5-20251001",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+    expect(d.overrideReason).toBe("doctrine_match");
+  });
+
+  it("Unknown agent kind on Opus stays on Opus — default would be Sonnet", () => {
+    const d = routeModel({
+      agentKind: "totally-unknown",
+      currentModel: "claude-opus-4-7",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("current_tier_floor");
+  });
+
+  it("HQ_MODEL_OVERRIDE=haiku DOES downgrade — explicit operator intent wins over current_tier_floor", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: "claude-sonnet-4-5-20250929",
+      env: { HQ_MODEL_OVERRIDE: "haiku" } as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("haiku");
+    expect(d.overrideReason).toBe("env_override");
+  });
+
+  it("hard floor still wins over current_tier_floor — never let an architect downgrade", () => {
+    // (Edge case — architect on Haiku is unusual but doctrine should still escalate.)
+    const d = routeModel({
+      agentKind: "architect",
+      currentModel: "claude-haiku-4-5-20251001",
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+    expect(d.overrideReason).toBe("hard_floor");
+  });
+});
+
+describe("routeModel — robustness", () => {
+  it("handles null agentKind without throwing", () => {
+    const d = routeModel({
+      agentKind: null,
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+    expect(d.overrideReason).toBe("default");
+  });
+
+  it("handles undefined env without throwing", () => {
+    const d = routeModel({
+      agentKind: "Builder",
+      currentModel: null,
+      env: {} as NodeJS.ProcessEnv,
+    });
+    expect(d.tier).toBe("sonnet");
+  });
+
+  it("higher-priority opus row beats sonnet match on a multi-keyword agent kind", () => {
+    const d = routeModel({
+      agentKind: "principal-architect-engineer",
+      currentModel: null,
+      env: noEnv,
+    });
+    expect(d.tier).toBe("opus");
+  });
+});
