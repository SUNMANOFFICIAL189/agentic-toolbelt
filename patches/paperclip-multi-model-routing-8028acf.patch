@@ -0,0 +1,228 @@
+/**
+ * Model routing function — typed implementation of HQ Commander's
+ * MODEL_ROUTING.md §3 decision algorithm, narrowed to Paperclip's
+ * agent-dispatch surface.
+ *
+ * Pure function. No side effects, no I/O. The caller (heartbeat.ts)
+ * logs the decision and applies it to the resolved config.
+ *
+ * Insertion site: server/src/services/heartbeat.ts after
+ * resolveExecutionRunAdapterConfig completes, before the adapter is invoked.
+ */
+
+import {
+  DEFAULT_TIER,
+  HARD_FLOOR_PATTERNS,
+  KEYWORD_TIER_TABLE,
+  TIER_RANK,
+  TIER_TO_MODEL,
+  type Tier,
+} from "./doctrine.js";
+
+export interface RouteModelInput {
+  /** Free-text describing the agent role/kind. e.g. "Validator", "CTO", "researcher". */
+  agentKind: string | null | undefined;
+  /** Optional task description (issue title + body). V1 uses agentKind only; held for v2. */
+  taskDescription?: string | null | undefined;
+  /** Currently configured model on the agent's adapterConfig.model — preserved if router is OFF. */
+  currentModel: string | null | undefined;
+  /** Process env or a subset thereof. Read for HQ_* overrides. */
+  env: NodeJS.ProcessEnv | Record<string, string | undefined>;
+}
+
+export type OverrideReason =
+  | "router_off"
+  | "non_anthropic_passthrough"
+  | "env_override"
+  | "doctrine_match"
+  | "hard_floor"
+  | "default"
+  | "floor_raised"
+  | "current_tier_floor";
+
+export interface RoutingDecision {
+  /** The concrete model string to put on config.model. */
+  model: string;
+  /** Tier the model resolves to. */
+  tier: Tier;
+  /** Why this decision was made — for the cost ledger / audit log. */
+  overrideReason: OverrideReason;
+  /** If a doctrine row matched, the matching keyword. null otherwise. */
+  matchedKeyword: string | null;
+  /** True if router was bypassed entirely (HQ_ROUTER_OFF=1). model == currentModel. */
+  passthrough: boolean;
+}
+
+/**
+ * Apply HQ doctrine to choose a model for a Paperclip agent dispatch.
+ *
+ * Hierarchy (first match wins; hard floor and HQ_MODEL_FLOOR can only escalate):
+ *   1. HQ_ROUTER_OFF=1                  → passthrough (model unchanged)
+ *   2. currentModel is non-Anthropic    → passthrough (preserve cross-provider choice)
+ *   3. Pick candidate tier:
+ *        a. HQ_MODEL_OVERRIDE=<tier>    → that tier (operator's explicit intent)
+ *        b. Doctrine keyword match      → tier from KEYWORD_TIER_TABLE
+ *        c. Default                     → sonnet
+ *   4. current_tier_floor — for non-override flows ONLY: raise to currentTier
+ *      if it's higher (never downgrade an operator's deliberate choice).
+ *   5. Hard floor (§4)                  → forces opus, beats steps 3 + 4.
+ *   6. HQ_MODEL_FLOOR=<tier>            → raises only; never lowers.
+ *
+ * Failure semantics: this function never throws. If anything is malformed,
+ * it returns a "default" decision (sonnet).
+ *
+ * The two safety rules added 2026-05-08 (steps 2 and 4) prevent the router
+ * from re-creating the 2026-04-28 quota-incident shape:
+ *   - Step 2 keeps cross-provider choices (Gemini, etc.) untouched.
+ *   - Step 4 ensures doctrine can only escalate operator config, never lower it.
+ */
+export function routeModel(input: RouteModelInput): RoutingDecision {
+  const env = input.env ?? {};
+  const currentModel = (input.currentModel ?? "").trim();
+
+  // 1. Router-off short-circuit (always honoured first)
+  if (env.HQ_ROUTER_OFF === "1") {
+    return {
+      model: currentModel,
+      tier: tierForModel(currentModel) ?? DEFAULT_TIER,
+      overrideReason: "router_off",
+      matchedKeyword: null,
+      passthrough: true,
+    };
+  }
+
+  // 2. Non-Anthropic short-circuit (added 2026-05-08).
+  //    If the operator deliberately moved an agent off Claude (e.g., to
+  //    gemini-2.5-flash or gpt-4), the router must not pull it back. Cross-
+  //    provider decisions are out of doctrine scope.
+  if (currentModel && !isAnthropicModel(currentModel)) {
+    return {
+      model: currentModel,
+      tier: DEFAULT_TIER, // tier is informational only on passthrough
+      overrideReason: "non_anthropic_passthrough",
+      matchedKeyword: null,
+      passthrough: true,
+    };
+  }
+
+  const agentKind = (input.agentKind ?? "").trim().toLowerCase();
+  const currentTier = tierForModel(currentModel);
+
+  // 3. Pick candidate tier
+  let tier: Tier;
+  let overrideReason: OverrideReason;
+  let matchedKeyword: string | null = null;
+
+  const envOverride = parseTier(env.HQ_MODEL_OVERRIDE);
+  if (envOverride) {
+    tier = envOverride;
+    overrideReason = "env_override";
+    // env_override is operator's explicit per-session intent — current_tier_floor
+    // does NOT apply here. If the operator wants HQ_MODEL_OVERRIDE=haiku they
+    // mean it; the safety net is that they typed it.
+  } else {
+    const matched = matchDoctrine(agentKind);
+    if (matched) {
+      tier = matched.tier;
+      overrideReason = "doctrine_match";
+      matchedKeyword = matched.keyword;
+    } else {
+      tier = DEFAULT_TIER;
+      overrideReason = "default";
+    }
+
+    // 4. current_tier_floor (added 2026-05-08).
+    //    If the operator currently has the agent on a HIGHER tier than doctrine
+    //    picked, keep the operator's choice. Doctrine can only escalate, not
+    //    downgrade. (Skipped when env_override is set — explicit user intent.)
+    if (currentTier && TIER_RANK[currentTier] > TIER_RANK[tier]) {
+      tier = currentTier;
+      overrideReason = "current_tier_floor";
+    }
+  }
+
+  // 5. Hard-floor guard — adversarial / high-stakes work always escalates to Opus.
+  //    Beats env_override and current_tier_floor.
+  if (matchesHardFloor(agentKind)) {
+    tier = "opus";
+    overrideReason = "hard_floor";
+  }
+
+  // 6. HQ_MODEL_FLOOR — session-wide safety raise. Only raises, never lowers.
+  const floor = parseTier(env.HQ_MODEL_FLOOR);
+  if (floor && TIER_RANK[floor] > TIER_RANK[tier]) {
+    tier = floor;
+    overrideReason = "floor_raised";
+  }
+
+  return {
+    model: TIER_TO_MODEL[tier],
+    tier,
+    overrideReason,
+    matchedKeyword,
+    passthrough: false,
+  };
+}
+
+// ---------------------------------------------------------------------------
+// Internals
+// ---------------------------------------------------------------------------
+
+function parseTier(value: string | undefined | null): Tier | null {
+  if (typeof value !== "string") return null;
+  const v = value.trim().toLowerCase();
+  if (v === "haiku" || v === "sonnet" || v === "opus") return v;
+  return null;
+}
+
+function tierForModel(model: string): Tier | null {
+  const m = model.toLowerCase();
+  if (m.includes("haiku")) return "haiku";
+  if (m.includes("sonnet")) return "sonnet";
+  if (m.includes("opus")) return "opus";
+  return null;
+}
+
+/**
+ * Anthropic-shaped model strings (case-insensitive).
+ * Examples that match: "claude-sonnet-4-6", "Claude-Haiku-4-5-20251001",
+ *   "claude-opus-4-7", "claude-foo-99" (unknown but Claude-shaped).
+ * Examples that do NOT match: "gemini-2.5-flash", "gpt-4", "kimi-k2".
+ *
+ * Heuristic: starts with "claude" or contains "anthropic". This intentionally
+ * accepts unknown Claude-shaped strings so a future model name like
+ * "claude-future-99" is treated as routable rather than passed through.
+ */
+function isAnthropicModel(model: string): boolean {
+  const m = model.toLowerCase().trim();
+  return m.startsWith("claude") || m.includes("anthropic");
+}
+
+interface DoctrineMatch {
+  tier: Tier;
+  keyword: string;
+  priority: number;
+}
+
+function matchDoctrine(agentKind: string): DoctrineMatch | null {
+  if (!agentKind) return null;
+  let best: DoctrineMatch | null = null;
+  for (const row of KEYWORD_TIER_TABLE) {
+    for (const kw of row.keywords) {
+      if (agentKind.includes(kw)) {
+        if (!best || row.priority > best.priority || TIER_RANK[row.tier] > TIER_RANK[best.tier]) {
+          best = { tier: row.tier, keyword: kw, priority: row.priority };
+        }
+      }
+    }
+  }
+  return best;
+}
+
+function matchesHardFloor(agentKind: string): boolean {
+  if (!agentKind) return false;
+  for (const pattern of HARD_FLOOR_PATTERNS) {
+    if (agentKind.includes(pattern)) return true;
+  }
+  return false;
+}
